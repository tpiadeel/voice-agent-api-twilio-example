# AssemblyAI Voice Agent API (required)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Voice Agent WebSocket endpoint (default shown)
# AAI_AGENT_URL=wss://agents.assemblyai.com/v1/realtime

# Public hostname for Twilio media streams (e.g. https://abc.ngrok.app)
PUBLIC_HOSTNAME=https://your-ngrok-domain.ngrok.app

# Optional: server port (defaults to 3000)
# PORT=3000

# Optional: TTS voices per flow (defaults: ivy / winter). e.g. ivy, winter, claire
# INBOUND_VOICE=ivy
# OUTBOUND_VOICE=winter

# Optional: enable agent tools (generate_random_number, end_call). Default on.
# Set to "false" to disable. Note: disabling also removes outbound end_call.
# ENABLE_TOOLS=true

# Optional (outbound only): tuning to stop the greeting's first words being
# clipped while the callee's audio path opens after pickup.
#   _DELAY_MS — wait before greeting; silence is streamed during this window.
#   _PAD_MS   — silence cushion queued immediately before the first words.
# Increase if the start is still clipped; decrease for a snappier greeting.
# OUTBOUND_GREETING_DELAY_MS=2000
# OUTBOUND_GREETING_PAD_MS=500

# Outbound calling (only required for npm run outbound)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TARGET_PHONE_NUMBER=

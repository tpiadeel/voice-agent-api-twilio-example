# AssemblyAI Voice Agent API (required)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Voice Agent WebSocket endpoint (default shown)
# AAI_AGENT_URL=wss://agents.assemblyai.com/v1/realtime

# Public hostname for Twilio media streams (e.g. https://abc.ngrok.app)
HOSTNAME=https://your-ngrok-domain.ngrok.app

# Optional: server port (defaults to 3000)
# PORT=3000

# Outbound calling (only required for npm run outbound)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TARGET_PHONE_NUMBER=
